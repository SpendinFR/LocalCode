{
  "env": {
    "LLAMA_API_KEY": "local"
  },
  "modelProviders": {
    "openai": [
      {
        "id": "qwen35-9b",
        "name": "Qwen 3.5 9B - planner, scout and judge",
        "envKey": "LLAMA_API_KEY",
        "baseUrl": "http://127.0.0.1:8080/v1",
        "generationConfig": {
          "timeout": 900000,
          "maxRetries": 1,
          "contextWindowSize": 8192,
          "samplingParams": {
            "temperature": 0.05,
            "top_p": 0.8,
            "max_tokens": 4096
          }
        }
      },
      {
        "id": "qwen3coder30-iq2",
        "name": "Qwen 3 Coder 30B A3B UD-IQ2_XXS - coder",
        "envKey": "LLAMA_API_KEY",
        "baseUrl": "http://127.0.0.1:8080/v1",
        "generationConfig": {
          "timeout": 1200000,
          "maxRetries": 1,
          "contextWindowSize": 8192,
          "samplingParams": {
            "temperature": 0.1,
            "top_p": 0.8,
            "max_tokens": 4096
          }
        }
      },
      {
        "id": "qwen25coder14-q3",
        "name": "Qwen 2.5 Coder 14B Q3_K_M - independent reviewer",
        "envKey": "LLAMA_API_KEY",
        "baseUrl": "http://127.0.0.1:8080/v1",
        "generationConfig": {
          "timeout": 900000,
          "maxRetries": 1,
          "contextWindowSize": 8192,
          "samplingParams": {
            "temperature": 0.0,
            "top_p": 0.75,
            "max_tokens": 4096
          }
        }
      }
    ]
  },
  "memory": {
    "enableManagedAutoMemory": false,
    "enableManagedAutoDream": false
  },
  "tools": {
    "shell": {
      "enableInteractiveShell": false
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "^(read_file|grep_search|glob|read_many_files|read_multiple_files|run_shell_command|write_file|edit)$",
        "hooks": [
          {
            "type": "command",
            "command": "python .microagent/context_guard.py",
            "name": "microagent-context-guard",
            "timeout": 10000
          }
        ]
      }
    ]
  }
}
